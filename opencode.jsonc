{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "engram": {
      "command": ["engram", "mcp"],
      "enabled": true,
      "type": "local",
    },
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
    },
  },
}
